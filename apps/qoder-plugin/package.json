{
  "name": "@plannotator/qoder",
  "version": "0.14.2",
  "description": "Plannotator MCP server for Qoder CLI - interactive plan review with visual annotation",
  "author": "backnotprop",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/backnotprop/plannotator.git",
    "directory": "apps/qoder-plugin"
  },
  "homepage": "https://github.com/backnotprop/plannotator",
  "bugs": {
    "url": "https://github.com/backnotprop/plannotator/issues"
  },
  "keywords": [
    "qoder",
    "qoder-cli",
    "mcp",
    "plannotator",
    "plan-review",
    "ai-agent",
    "coding-agent"
  ],
  "main": "dist/index.js",
  "bin": {
    "plannotator-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "commands",
    "README.md",
    "plannotator.html",
    "review-editor.html"
  ],
  "scripts": {
    "build": "cp ../hook/dist/index.html ./plannotator.html && cp ../review/dist/index.html ./review-editor.html && bun build index.ts --outfile dist/index.js --target bun --external @modelcontextprotocol/sdk",
    "postinstall": "mkdir -p ${XDG_CONFIG_HOME:-$HOME/.config}/qoder/command && cp ./commands/*.md ${XDG_CONFIG_HOME:-$HOME/.config}/qoder/command/ 2>/dev/null || true",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@plannotator/server": "workspace:*",
    "@plannotator/shared": "workspace:*",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  }
}
